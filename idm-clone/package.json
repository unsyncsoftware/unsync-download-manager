{
  "name": "unsync-download-manager",
  "version": "0.1.0",
  "description": "Unsync Download Manager — a fast, free IDM alternative by UnSync Software",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && copy src\\preload.js dist\\preload.js",
    "start": "npm run build:all && electron .",
    "dev": "concurrently \"tsc --watch\" \"nodemon --watch dist/main.js --exec electron .\"",
    "build:renderer": "cd renderer && npx vite build",
    "build:all": "npm run build && npm run build:renderer",
    "package": "npm run build:all && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "axios-cookiejar-support": "^7.0.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "uk.unsync.downloadmanager",
    "productName": "Unsync Download Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
